{
    "name": "techenby/docify",
    "description": "Add documentation viewer to your Laravel and Livewire application",
    "keywords": [
        "techenby",
        "docify",
        "documentation",
        "laravel",
        "livewire",
        "php"
    ],
    "homepage": "https://github.com/tighten/docify",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Swick",
            "email": "andy@techenby.com",
            "homepage": "https://techenby.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "livewire/flux": "^2.0",
        "livewire/livewire": "^4.0",
        "pomodocs/commonmark-alert": "*",
        "tempest/highlight": "^2.22"
    },
    "require-dev": {
        "pestphp/pest": "^3.8.5|^4.6.2",
        "orchestra/testbench": "^9.0|^10.9.0|^11.1",
        "tightenco/duster": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "TechEnby\\Docify\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TechEnby\\Docify\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TechEnby\\Docify\\DocifyServiceProvider"
            ],
            "aliases": {
                "Docify": "TechEnby\\Docify\\DocifyFacade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
